    "https://www.khan.co.kr/rss/rssdata/total_news.xml", // 5 경향신문
    "https://www.hankyung.com/feed/all-news",            // 6 한국경제
    "https://www.hani.co.kr/rss/",                       // 7 한겨레
    "http://www.ohmynews.com/rss/ohmynews.xml",          // 8 오마이뉴스
    "https://www.mk.co.kr/rss/40300001/",                // 9 매일경제
    "https://sports.khan.co.kr/rss/k-culture",           // 10 스포츠경향 K-Culture
    "https://sports.khan.co.kr/rss/entertainment",       // 11 스포츠경향 연예
    "https://sports.khan.co.kr/rss/soccer",              // 12 스포츠경향 축구
    "https://sports.khan.co.kr/rss/life",                // 13 스포츠경향 라이프
    "https://www.newsis.com/RSS/politics.xml",           // 14 뉴시스 정치
    "https://www.newsis.com/RSS/economy.xml",            // 15 뉴시스 경제
    "https://www.newsis.com/RSS/society.xml",            // 16 뉴시스 사회
    "https://www.newsis.com/RSS/international.xml",      // 17 뉴시스 국제
];

const results = await Promise.allSettled(urls.map((u) => fetchRSS(u)));
const f = (i) => (results[i].status === "fulfilled" && results[i].value) ? results[i].value : null;

const yPol = f(0);  const yEco = f(1);  const ySoc = f(2);  const yInt = f(3);
const donga = f(4);  const khan = f(5);  const hankyung = f(6);
const hani = f(7);   const ohmy = f(8);  const mk = f(9);
const skK = f(10);   const skE = f(11);  const skS = f(12);  const skL = f(13);
const nPol = f(14);  const nEco = f(15);  const nSoc = f(16);  const nInt = f(17);

// 카드 헬퍼
const YNA = (badge, data) => ({ data, source: "연합뉴스", badge, bg: "#0ffd02", text: "#000", grad: "linear-gradient(135deg, #1f251f, #0a0e0a)" });
const NEWSIS = (badge, data) => ({ data, source: "뉴시스", badge, bg: "#0ffd02", text: "#000", grad: "linear-gradient(135deg, #1f251f, #0a0e0a)" });
const R = (source, data) => ({ data, source, badge: "RIGHT", bg: "#FF3B3B", text: "#fff", grad: "linear-gradient(135deg, #2a0f0f, #0a0e0a)" });
const L = (source, data) => ({ data, source, badge: "LEFT", bg: "#3B7BFF", text: "#fff", grad: "linear-gradient(135deg, #0f182a, #0a0e0a)" });
const C = (data) => ({ data, source: "스포츠경향", badge: "문화", bg: "#0ffd02", text: "#000", grad: "linear-gradient(135deg, #1f251f, #0a0e0a)" });

const BATCH_SIZE = 12;
const MAX_BATCH = 6;

const feedsConfig = [
    // ===== BATCH 1 (초기 표시) =====
    YNA("정치", yPol?.[0]),  YNA("경제", yEco?.[0]),
    YNA("사회", ySoc?.[0]),  YNA("국제", yInt?.[0]),
    YNA("국제", yInt?.[1]),  YNA("국제", yInt?.[2]),
    R("동아일보", donga?.[0]),   L("경향신문", khan?.[0]),
    R("한국경제", hankyung?.[0]), L("한겨레", hani?.[0]),
    R("동아일보", donga?.[1]),   L("오마이뉴스", ohmy?.[0]),

    // ===== BATCH 2 =====
    YNA("정치", yPol?.[1]),  YNA("경제", yEco?.[1]),
    YNA("사회", ySoc?.[1]),  YNA("국제", yInt?.[3]),
    YNA("국제", yInt?.[4]),  YNA("국제", yInt?.[5]),
    R("동아일보", donga?.[2]),   L("경향신문", khan?.[1]),
    R("한국경제", hankyung?.[1]), L("한겨레", hani?.[1]),
    R("동아일보", donga?.[3]),   L("오마이뉴스", ohmy?.[1]),

    // ===== BATCH 3 =====
    YNA("정치", yPol?.[2]),  YNA("경제", yEco?.[2]),
    YNA("사회", ySoc?.[2]),  YNA("국제", yInt?.[6]),
    YNA("국제", yInt?.[7]),  YNA("국제", yInt?.[8]),
