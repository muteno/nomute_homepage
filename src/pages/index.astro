    R("한국경제", hankyung?.[2]), L("한겨레", hani?.[2]),
    R("매일경제", mk?.[0]),      C(skE?.[0]),  // 스포츠경향 연예

    // ===== BATCH 4 =====
    YNA("정치", yPol?.[3]),  YNA("경제", yEco?.[3]),
    YNA("사회", ySoc?.[3]),  YNA("국제", yInt?.[9]),
    YNA("국제", yInt?.[10]), YNA("국제", yInt?.[11]),
    C(skL?.[0]),                 L("경향신문", khan?.[3]),  // 스포츠경향 라이프
    R("한국경제", hankyung?.[3]), C(skK?.[0]),               // 스포츠경향 K-Culture
    R("동아일보", donga?.[5]),   L("오마이뉴스", ohmy?.[2]),

    // ===== BATCH 5 =====
    YNA("정치", yPol?.[4]),  YNA("경제", yEco?.[4]),
    YNA("사회", ySoc?.[4]),  YNA("국제", yInt?.[12]),
    YNA("국제", yInt?.[13]), YNA("국제", yInt?.[14]),
    R("매일경제", mk?.[1]),      L("경향신문", khan?.[4]),
    R("한국경제", hankyung?.[4]), L("한겨레", hani?.[3]),
    C(skK?.[1]),                 C(skE?.[1]),  // K-Culture, 연예

    // ===== BATCH 6 (뉴시스) =====
    NEWSIS("정치", nPol?.[0]),  NEWSIS("경제", nEco?.[0]),
    NEWSIS("사회", nSoc?.[0]),  NEWSIS("국제", nInt?.[0]),
    NEWSIS("국제", nInt?.[1]),  NEWSIS("국제", nInt?.[2]),
    R("매일경제", mk?.[2]),      L("경향신문", khan?.[5]),
