---
// src/pages/index.astro — 노뮤트 홈
// 디자인 = nomute-editor viewer :root 토큰 이식(값 복사·정본은 에디터), RSS 편성 = src/lib/feeds.ts(소스별 큐→중복제거→성향 슬롯).
import { buildCards } from "../lib/feeds";

const cards = await buildCards();
const maxBatch = cards.length ? Math.max(...cards.map((c) => c.batch)) : 1;

// 빌드 시점 초기값 — 클라이언트가 즉시 실시간 갱신(KST 기준 상대시간)
function timeAgo(iso: string | null): string {
    if (!iso) return "-";
    const diffMs = Date.now() - new Date(iso).getTime();
    const minutes = Math.max(0, Math.floor(diffMs / 60000));
    if (minutes < 60) return "방금 전";
    if (minutes < 1440) return Math.floor(minutes / 60) + "시간 전";
    return Math.floor(minutes / 1440) + "일 전";
}
