<!doctype html>
<html lang="ko">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
        />
        <title>No Mute - THE VOICE OF THE UNHEARD.</title>
        <meta
            name="description"
            content="No Mute - 불편한 진실을 대면할 현명한 당신을 위합니다."
        />

        <!-- Google Fonts: DM Sans & Noto Sans KR -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@700&family=Noto+Sans+KR:wght@400;700;900&display=swap"
            rel="stylesheet"
        />

        <style>
            /* Custom Local Fonts */
            @font-face {
                font-family: "LEMONMILK";
                src: url("/fonts/LEMONMILK-Bold.otf") format("opentype");
                font-weight: bold;
                font-style: normal;
            }

            @font-face {
                font-family: "Whitney";
                src: url("/fonts/whitney-bold.otf") format("opentype");
                font-weight: bold;
                font-style: normal;
            }

            :root {
                --bg-base: #020402;
                --accent-green: #0ffd02;
                --text-main: #ffffff;
                --text-muted: #aaaaaa;
                --card-bg: rgba(20, 20, 20, 0.4);
                --border-color: rgba(255, 255, 255, 0.08);
                --font-stack:
                    "LEMONMILK", "Whitney", "Noto Sans KR", sans-serif;
                --font-kr: "Noto Sans KR", sans-serif;
                --font-dm: "DM Sans", "Noto Sans KR", sans-serif;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                -webkit-tap-highlight-color: transparent;
            }

            html,
            body {
                width: 100%;
            }

            body {
                font-family: var(--font-stack);
                background-color: var(--bg-base);
                color: var(--text-main);
                line-height: 1.5;
                -webkit-font-smoothing: antialiased;
            }

            /* 1. Mobile Background Image (Default) */
            .bg-dark-wave {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: -1;
                background-color: var(--bg-base);
                background-image: url("/assets/background.png");
                background-size: cover;
                background-attachment: fixed;
                background-position: center;
            }

            /* Video elements (Hidden on mobile by default) */
            .pc-video-bg {
                display: none;
            }
            .pc-video-overlay {
                display: none;
            }

            .highlight {
                color: var(--accent-green);
            }

            /* Force Korean font where appropriate without breaking English fonts */
            .kor {
                font-family: var(--font-kr);
            }

            /* VIEW TOGGLE */
            .pc-view {
                display: none;
            }
            .mobile-view {
                display: flex;
                flex-direction: column;
                width: 100%;
                min-height: 100vh;
            }

            /* ======== MOBILE STYLES ======== */
            .mobile-container {
                width: 100%;
                max-width: 480px;
                margin: 0 auto;
                position: relative;
                display: flex;
                flex-direction: column;
                z-index: 1;
                padding-bottom: 60px;
            }

            /* Header / Logo */
            #mobile-header {
                padding: 16px 24px;
                padding-top: 16px;
                display: flex;
                justify-content: flex-start;
                align-items: center;
                gap: 12px;
                position: sticky;
                top: 0;
                z-index: 1000;
            }

            /* Full viewport width background for blocking behind sticky nav */
            #mobile-header::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                transform: none;
                width: 100%;
                height: 96%; /* Shortened fade */
                background: linear-gradient(
                    180deg,
                    rgba(2, 4, 2, 0.98) 40%,
                    rgba(2, 4, 2, 0.7) 70%,
                    transparent 100%
                );
                z-index: -1;
                pointer-events: none;
                transition:
                    background 0.3s ease,
                    backdrop-filter 0.3s ease,
                    -webkit-backdrop-filter 0.3s ease;
            }

            #mobile-header.scrolled::before {
                background: linear-gradient(
                    180deg,
                    rgba(0, 0, 0, 0.98) 40%,
                    rgba(0, 0, 0, 0.8) 70%,
                    transparent 100%
                );
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
            }

            .logo-img {
                height: 64px;
                width: auto;
                flex-shrink: 0;
                transition: height 0.3s ease;
                margin-top: 6px;
            }

            #mobile-header.scrolled .logo-img {
                height: 52px;
            }

            .header-text-container {
                font-family: var(--font-kr);
                font-size: 3.5vw;
                font-weight: 700;
                line-height: 1.4;
                color: rgba(255, 255, 255, 0.9);
                opacity: 0;
                transform: translateX(-10px);
                transition:
                    opacity 0.4s ease,
                    transform 0.4s ease;
                white-space: nowrap;
                pointer-events: none;
            }

            #mobile-header.scrolled .header-text-container {
                opacity: 1;
                transform: translateX(0);
                pointer-events: auto;
            }

            /* Hero */
            .hero {
                padding: 40px 24px 30px;
                text-align: left;
            }
            .hero h1 {
                font-family: "LEMONMILK", sans-serif;
                font-size: 46px;
                line-height: 1.1;
                margin-bottom: 24px;
                letter-spacing: -1px;
                text-transform: uppercase;
            }
            .hero p.sub-copy {
                font-family: var(--font-kr);
                font-size: 16px;
                font-weight: 700;
                color: rgba(255, 255, 255, 0.85);
                letter-spacing: -0.5px;
                word-break: keep-all;
                margin-bottom: 40px;
                line-height: 1.5;
            }

            /* News Cards */
            .latest-news {
                padding: 0 24px 40px;
            }
            .section-title {
                font-size: 18px;
                font-weight: 800;
                margin-bottom: 24px;
                display: flex;
                align-items: center;
                gap: 8px;
                letter-spacing: 0.5px;
                font-family: "LEMONMILK", sans-serif;
            }
            .section-title::before {
                content: "";
                display: block;
                width: 4px;
                height: 18px;
                background-color: var(--accent-green);
            }
            .loading-skeleton {
                animation: pulse-skeleton 1.5s infinite ease-in-out;
                pointer-events: none;
            }
            .loading-skeleton .news-title {
                color: rgba(255, 255, 255, 0.5);
            }
            @keyframes pulse-skeleton {
                0% {
                    opacity: 0.6;
                }
                50% {
                    opacity: 1;
                }
                100% {
                    opacity: 0.6;
                }
            }
            .news-card {
                background-color: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                overflow: hidden;
                margin-bottom: 20px;
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                transition:
                    transform 0.2s ease,
                    border-color 0.3s ease;
            }
            .news-card:active {
                transform: scale(0.98);
                border-color: var(--accent-green);
            }
            .news-image {
                width: 100%;
                height: 200px;
                background-color: #0a0e0a;
                position: relative;
            }
            .news-badge {
                position: absolute;
                bottom: 0;
                left: 20px;
                transform: translateY(50%);
                z-index: 10;
                background-color: var(--accent-green);
                color: #000;
                padding: 4px 10px;
                font-size: 12px;
                font-family: "LEMONMILK", sans-serif;
                border-radius: 4px;
                text-transform: uppercase;
            }
            .news-content {
                padding: 28px 20px 20px 20px;
            }
            .news-title {
                font-family: var(--font-kr);
                font-size: 18px;
                font-weight: 700;
                margin-bottom: 12px;
                line-height: 1.4;
                color: #fff;
                letter-spacing: -0.5px;
            }
            .news-meta {
                font-family: var(--font-kr);
                font-size: 13px;
                color: var(--text-muted);
                display: flex;
                justify-content: space-between;
            }

            .no-ads-notice {
                font-family: var(--font-kr);
                font-size: 12px;
                color: #888888;
                text-align: center;
                margin-top: 16px;
            }

            /* Instagram CTA */
            .instagram-cta {
                margin: 30px 0 40px;
                background: rgba(20, 25, 20, 0.6);
                border: 1px solid rgba(15, 253, 2, 0.4);
                border-radius: 20px;
                padding: 40px 24px;
                text-align: center;
                backdrop-filter: blur(12px);
            }
            .instagram-cta h2 {
                font-family: "LEMONMILK", sans-serif;
                font-size: 24px;
                margin-bottom: 12px;
                color: #fff;
            }
            .instagram-cta p {
                font-family: var(--font-dm);
                font-weight: 700;
                font-size: 15px;
                margin-bottom: 28px;
                color: var(--text-muted);
                line-height: 1.5;
                word-break: keep-all;
            }
            .btn-instagram {
                display: inline-block;
                background-color: var(--accent-green);
                color: #000;
                text-decoration: none;
                padding: 16px 32px;
                border-radius: 30px;
                font-family: var(--font-dm);
                font-weight: 700;
                font-size: 16px;
                transition: all 0.3s ease;
                letter-spacing: -0.5px;
                width: 100%;
                box-sizing: border-box;
            }
            .btn-instagram:active {
                transform: translateY(2px);
                opacity: 0.9;
            }

            /* Floating Load More Button */
            #floating-load-more {
                position: fixed;
                top: 75%;
                left: 80%;
                bottom: auto;
                right: auto;
                transform: translate(-50%, -50%);
                margin: 0;
                width: 72px;
                height: 72px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.03);
                backdrop-filter: blur(40px);
                -webkit-backdrop-filter: blur(40px);
                border: 1px solid rgba(255, 255, 255, 0.08);
                color: #ffffff;
                font-family: "Noto Sans KR", sans-serif;
                font-weight: 700;
                font-size: 13px;
                line-height: 1.3;
                text-align: center;
                cursor: pointer;
                z-index: 999;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0;
                transition: none;
                box-shadow: none;
                touch-action: manipulation;
                -webkit-touch-callout: none;
                user-select: none;
                -webkit-user-select: none;
                pointer-events: auto !important;
                z-index: 99999;
            }
            #floating-load-more:active {
                transform: scale(0.92);
            }

            /* Footer */
            footer {
                padding: 40px 24px 60px;
                border-top: 1px solid var(--border-color);
                color: var(--text-muted);
                font-size: 13px;
                text-align: center;
                font-family: var(--font-dm);
                font-weight: 700;
            }
            .footer-logo {
                font-size: 18px;
                font-family: var(--font-dm);
                font-weight: 700;
                margin-bottom: 12px;
            }

            /* ======== PC STYLES ======== */
            @media (min-width: 768px) {
                .mobile-view {
                    display: none;
                }

                /* PC Background Layout Override */
                .bg-dark-wave {
                    background-image: url("/assets/background.png");
                    background-size: cover;
                    background-position: center;
                    background-attachment: fixed;
                }

                .pc-view {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                    min-height: 100vh;
                    text-align: center;
                    z-index: 10;
                    position: relative;
                    padding: 40px;
                }

                .pc-main-copy {
                    font-family: "LEMONMILK", sans-serif;
                    font-size: 72px;
                    line-height: 1.1;
                    margin-bottom: 60px;
                    text-transform: uppercase;
                    letter-spacing: -1.5px;
                }

                .pc-logo-container {
                    margin-bottom: 40px;
                }
                .pc-logo-container img {
                    height: 60px;
                    width: auto;
                }

                .pc-sub-copy {
                    font-family: var(--font-kr);
                    font-size: 20px;
                    font-weight: 700;
                    color: rgba(255, 255, 255, 0.85);
                    margin-bottom: 60px;
                    letter-spacing: -0.5px;
                }

                .pc-glass-box {
                    background: rgba(255, 255, 255, 0.03);
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    backdrop-filter: blur(20px);
                    -webkit-backdrop-filter: blur(20px);
                    border-radius: 24px;
                    padding: 40px 60px;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
                    max-width: 500px;
                }

                .pc-glass-text {
                    font-family: var(--font-kr);
                    font-size: 16px;
                    color: var(--text-main);
                    font-weight: 400;
                    margin-bottom: 24px;
                    line-height: 1.6;
                    word-break: keep-all;
                    letter-spacing: -0.5px;
                }

                .pc-qr-img {
                    width: 200px;
                    height: 200px;
                    border-radius: 12px;
                    object-fit: contain;
                    box-shadow: 0 0 20px rgba(15, 253, 2, 0.15);
                }
            }
        </style>
    </head>
    <body>
        <!-- 1. Background (Image for Mobile and PC) -->
        <div class="bg-dark-wave"></div>

        <!-- 2. PC View (>= 768px) -->
        <div class="pc-view">
            <h1 class="pc-main-copy">
                <span class="highlight">Breaking</span><br />
                The Silence.<br />
                Speak the <span class="highlight">Truth</span>.
            </h1>

            <div class="pc-logo-container">
                <img src="/assets/logo.png" alt="No Mute Logo" />
            </div>

            <p class="pc-sub-copy kor">
                불편한 진실을 대면할 <span class="highlight"
                    >현명한 당신을 위합니다.</span
                >
            </p>

            <div class="pc-glass-box">
                <p class="pc-glass-text kor">
                    본 사이트는 모바일 환경에 최적화된 공간입니다.<br />아래
                    QR코드를 통해 모바일로 접속해주세요
                </p>
                <img
                    src="/assets/qr_instagram.png"
                    alt="QR Code to Instagram"
                    class="pc-qr-img"
                />
            </div>
        </div>

        <!-- 3. Mobile View (< 768px) -->
        <div class="mobile-view">
            <div class="mobile-container">
                <header id="mobile-header">
                    <img
                        src="/assets/logo.png"
                        alt="No Mute"
                        class="logo-img"
                    />
                    <div class="header-text-container">
                        불편한 진실을 대면할 <span class="highlight"
                            >현명한 당신을 위합니다.</span
                        >
                    </div>
                </header>

                <section class="hero">
                    <h1>
                        <span class="highlight">Breaking</span><br />The
                        Silence.<br />Speak the <span class="highlight"
                            >Truth</span
                        >.
                    </h1>
                    <p class="sub-copy kor">
                        불편한 진실을 대면할 <span class="highlight"
                            >현명한 당신을 위합니다.</span
                        >
                    </p>
                    <a
                        href="mailto:contact@nomute.kr"
                        style="display: block; margin-top: -12px; text-align: left; font-size: 13px; color: #BBBBBB; text-decoration: none; line-height: 1.5;"
                    >
                        <span
                            style="font-family: 'Noto Sans KR', sans-serif; font-weight: bold; text-decoration: underline;"
                            >Contact</span
                        ><br />
                        <span
                            style="font-family: 'Noto Sans KR', sans-serif; font-weight: normal;"
                            >Mail: <i>contact@nomute.kr</i></span
                        >
                    </a>
                </section>

                <section class="latest-news">
                    <h2 class="section-title">LATEST DROPS</h2>

                    {
                        feedsConfig.map((feed, index) => {
                            const hasData =
                                feed.data && feed.data.title !== "제목 없음";
                            const hasImage = hasData && feed.data.imageUrl;
                            return (
                                <>
                                    {index === 5 && (
                                        <div class="instagram-cta">
                                            <h2>JOIN THE MOVEMENT</h2>
                                            <p class="kor">
                                                Instagram에서{" "}
                                                <span
                                                    class="highlight"
                                                    style="font-weight: 700;"
                                                >
                                                    no_mute
                                                </span>
                                                가 전하는
                                                <br />
                                                가장 빠른 이슈 업데이트를
                                                확인하세요.
                                            </p>
                                            <a
                                                href="https://instagram.com/no_mute"
                                                class="btn-instagram"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                            >
                                                @no_mute 채널 팔로우
                                            </a>
                                        </div>
                                    )}
                                    <article
                                        class="news-card"
                                        style={
                                            feed.batch !== 1
                                                ? "display: none;"
                                                : ""
                                        }
                                        data-link={
                                            hasData ? feed.data.link : ""
                                        }
                                        data-batch={feed.batch}
                                    >
                                        {hasImage ? (
                                            <div class="news-image">
                                                <div
                                                    class="news-badge"
                                                    style={`background-color: ${feed.bg}; color: ${feed.text};`}
                                                >
                                                    {feed.badge}
                                                </div>
                                                <div
                                                    style={`width:100%; height:100%; background: url('${feed.data.imageUrl}') center/cover no-repeat, ${feed.grad};`}
                                                />
                                            </div>
                                        ) : null}
                                        <div class="news-content">
                                            {!hasImage && (
                                                <div
                                                    class="news-badge"
                                                    style={`background-color: ${feed.bg}; color: ${feed.text}; position: static; transform: none; display: inline-block; margin-bottom: 12px;`}
                                                >
                                                    {feed.badge}
                                                </div>
                                            )}
                                            <h3 class="news-title">
                                                {hasData
                                                    ? feed.data.title
                                                    : "기사를 불러올 수 없습니다"}
                                            </h3>
                                            <div class="news-meta">
                                                <span>{feed.source}</span>
                                                <span class="news-time">
                                                    {hasData
                                                        ? formatTimeAgo(
                                                              feed.data.pubDate,
                                                          )
                                                        : "-"}
                                                </span>
                                            </div>
                                        </div>
                                    </article>
                                </>
                            );
                        })
                    }

                    <button id="floating-load-more" style="display: none;">
                        더<br />보기
                    </button>

                    <div id="end-cta" style="display: none; margin-top: 24px;">
                        <div class="instagram-cta">
                            <h2>JOIN THE MOVEMENT</h2>
                            <p class="kor">
                                더 많은 뉴스는 Instagram
                                <span
                                    class="highlight"
                                    style="font-weight: 700;">no_mute</span
                                >
                                에서 확인하세요.
                            </p>
                            <a
                                href="https://instagram.com/no_mute"
                                class="btn-instagram"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                @no_mute 채널 팔로우
                            </a>
                        </div>
                    </div>
                </section>

                <footer>
                    <div
                        class="footer-logo"
                        style="font-family: 'Noto Sans KR', sans-serif; font-weight: 900;"
                    >
                        노뮤트 매거진
                    </div>
                    <p>ⓒ 2025-26. No_mute. All rights reserved.</p>
                    <p style="margin-top: 8px; opacity: 0.5;">
                        Break the silence. Speak the truth.
                    </p>
                </footer>
            </div>
        </div>

        <!-- Interactions -->
        <script>
            // Mobile Header Scroll Effect
            const mobileHeader = document.getElementById("mobile-header");
            const heroSection = document.querySelector(".hero");

            if (mobileHeader && heroSection) {
                window.addEventListener(
                    "scroll",
                    () => {
                        const heroBottom =
                            heroSection.getBoundingClientRect().bottom;
                        const headerHeight = mobileHeader.offsetHeight;

                        if (heroBottom <= headerHeight) {
                            mobileHeader.classList.add("scrolled");
                        } else {
                            mobileHeader.classList.remove("scrolled");
                        }
                    },
                    { passive: true },
                );
            }

            // Load More Button Logic (Intersection Observer)
            const floatingBtn = document.getElementById("floating-load-more");
            let currentBatch = 1;
            const maxBatch = 3;

            if (floatingBtn) {
                let scrollTimer;
                let lastCardVisible = false;

                const observer = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            lastCardVisible = entry.isIntersecting;
                            if (!entry.isIntersecting) {
                                floatingBtn.style.display = "none";
                            }
                        });
                    },
                    { threshold: 0.3 },
                );

                // 스크롤 멈춤 감지 - 멈춘 후에만 버튼 표시
                window.addEventListener(
                    "scroll",
                    () => {
                        floatingBtn.style.display = "none";
                        clearTimeout(scrollTimer);
                        scrollTimer = setTimeout(() => {
                            if (lastCardVisible && currentBatch < maxBatch) {
                                floatingBtn.style.display = "flex";
                            }
                        }, 400);
                    },
                    { passive: true },
                );

                function observeLastCard() {
                    observer.disconnect();
                    const currentCards = document.querySelectorAll(
                        `[data-batch="${currentBatch}"]`,
                    );
                    if (currentCards.length > 0) {
                        observer.observe(currentCards[currentCards.length - 1]);
                    }
                }

                observeLastCard();

                let isLoading = false;
                floatingBtn.addEventListener(
                    "pointerdown",
                    (e) => {
                        e.stopPropagation();
                        if (isLoading) return;
                        isLoading = true;

                        currentBatch++;
                        document
                            .querySelectorAll(`[data-batch="${currentBatch}"]`)
                            .forEach((card) => {
                                (card as HTMLElement).style.display = "block";
                            });
                        floatingBtn.style.display = "none";

                        if (currentBatch >= maxBatch) {
                            // 마지막 batch → 배너 표시, 버튼 완전 제거
                            observer.disconnect();
                            const endCta = document.getElementById("end-cta");
                            if (endCta) endCta.style.display = "block";
                            floatingBtn.remove();
                        } else {
                            // 다음 batch의 마지막 카드 감시 시작
                            observeLastCard();
                        }

                        setTimeout(() => {
                            isLoading = false;
                        }, 300);
                    },
                    { passive: false },
                );
            }

            // Mobile card tap interactions and link routing
            document.querySelectorAll(".news-card").forEach((card) => {
                const htmlCard = card as HTMLElement;
                const link = htmlCard.getAttribute("data-link");

                if (link) {
                    htmlCard.style.cursor = "pointer";
                    htmlCard.onclick = () => {
                        window.open(link, "_blank");
                    };
                }

                htmlCard.addEventListener("mousedown", () => {
                    htmlCard.style.transform = "scale(0.98)";
                });
                htmlCard.addEventListener("mouseup", () => {
                    htmlCard.style.transform = "scale(1)";
                });
                htmlCard.addEventListener("mouseleave", () => {
                    htmlCard.style.transform = "scale(1)";
                });

                // for touch devices
                htmlCard.addEventListener("touchstart", () => {
                    htmlCard.style.transform = "scale(0.98)";
                });
                htmlCard.addEventListener("touchend", () => {
                    htmlCard.style.transform = "scale(1)";
                });
            });
        </script>
    </body>
</html>
