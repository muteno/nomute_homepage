// src/pages/index.astro

// Helper to clean extracted text
function cleanStr(str) {
    if (!str) return "";
    let s = str.replace(/^<!\[CDATA\[([\s\S]*?)\]\]>$/gi, "$1").trim();
    return s
        .replace(/&lt;/g, "<")
        .replace(/&gt;/g, ">")
        .replace(/&amp;/g, "&")
        .replace(/&quot;/g, '"')
        .replace(/&#39;/g, "'");
}

// 빌드 시점 fetch Timeout
async function fetchWithTimeout(url, timeoutMs) {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), timeoutMs);
    try {
        const response = await fetch(url, { signal: controller.signal });
        clearTimeout(timeoutId);
        return response;
    } catch (error) {
        clearTimeout(timeoutId);
        throw error;
    }
}

// 원본 링크에서 og:image 파싱 (서버사이드)
async function fetchOgImage(linkUrl) {
    if (!linkUrl || linkUrl === "#") return null;
    try {
        const res = await fetchWithTimeout(linkUrl, 3000); // 3s timeout
        if (!res.ok) return null;
        const text = await res.text();
        const ogMatch =
            text.match(
                /<meta[^>]*property=["']og:image["'][^>]*content=["']([^"']+)["'][^>]*>/i,
            ) ||
            text.match(
                /<meta[^>]*content=["']([^"']+)["'][^>]*property=["']og:image["'][^>]*>/i,
            );
        if (ogMatch && ogMatch[1]) {
            return ogMatch[1].replace(/&amp;/g, "&");
        }
    } catch (e) {}
    return null;
}

// 서버사이드 RSS 피드 가져오기
async function fetchRSS(url) {
    try {
        const res = await fetchWithTimeout(url, 5000); // 5s timeout
        if (!res.ok) throw new Error("Fetch failed");
        const xml = await res.text();

        const items = [];
        const itemRegex = /<item[^>]*>([\s\S]*?)<\/item>/gi;
        let match;
        while ((match = itemRegex.exec(xml)) !== null) {
            const itemContent = match[1];

            const titleMatch = itemContent.match(
                /<title[^>]*>([\s\S]*?)<\/title>/i,
            );
            const linkMatch = itemContent.match(
                /<link[^>]*>([\s\S]*?)<\/link>/i,
            );
            const pubDateMatch =
                itemContent.match(/<pubDate[^>]*>([\s\S]*?)<\/pubDate>/i) ||
                itemContent.match(/<dc:date[^>]*>([\s\S]*?)<\/dc:date>/i);

            let imageUrl = null;

            // 1. enclosure
            if (!imageUrl) {
                const encMatch = itemContent.match(
                    /<enclosure[^>]*url=["']([^"']+)["']/i,
                );
                if (encMatch) imageUrl = encMatch[1];
            }
            // 2. media:content
            if (!imageUrl) {
                const mcMatch = itemContent.match(
                    /<media:content[^>]*url=["']([^"']+)["']/i,
                );
                if (mcMatch) imageUrl = mcMatch[1];
            }
            // 3. media:thumbnail
            if (!imageUrl) {
                const mtMatch = itemContent.match(
                    /<media:thumbnail[^>]*url=["']([^"']+)["']/i,
                );
                if (mtMatch) imageUrl = mtMatch[1];
            }
            // 4. description / content:encoded img 파싱
            if (!imageUrl) {
                const descMatch = itemContent.match(
                    /<(?:description|content:encoded)[^>]*>([\s\S]*?)<\/(?:description|content:encoded)>/i,
                );
                if (descMatch) {
                    const imgMatch = descMatch[1].match(
                        /<img[^>]+src=["']([^"']+)["']/i,
                    );
                    if (imgMatch) imageUrl = imgMatch[1];
                }
            }

            const link = linkMatch ? cleanStr(linkMatch[1]) : "#";

            items.push({
                title: titleMatch ? cleanStr(titleMatch[1]) : "제목 없음",
                link: link,
                pubDate: pubDateMatch
                    ? cleanStr(pubDateMatch[1])
                    : new Date().toISOString(),
                imageUrl: imageUrl || null,
            });
        }

        // 5. og:image fallback execution
        for (let item of items) {
            if (!item.imageUrl && item.link !== "#") {
                item.imageUrl = await fetchOgImage(item.link);
            }
        }

        return items.length > 0 ? items : null;
    } catch (error) {
        console.error("RSS Fetch Error for", url, error.message);
        return null;
    }
}

// 시간 계산 (정적 HTML 빌드 시점에 고정)
function formatTimeAgo(dateString) {
    const pubDate = new Date(dateString);
    const now = new Date();
    if (isNaN(pubDate.getTime())) return "-";
    const diffMs = now.getTime() - pubDate.getTime();
    const minutes = Math.max(0, Math.floor(diffMs / 60000));

    if (minutes < 60) return "방금 전";
    if (minutes < 1440) return Math.floor(minutes / 60) + "시간 전";
    return Math.floor(minutes / 1440) + "일 전";
}

