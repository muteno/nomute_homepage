---

<!doctype html>
<html lang="ko">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
        />
        <title>No Mute - THE VOICE OF THE UNHEARD.</title>
        <meta
            name="description"
            content="No Mute - 불편한 진실을 대면할 현명한 당신을 위합니다."
        />

        <!-- Google Fonts: DM Sans & Noto Sans KR -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@700&family=Noto+Sans+KR:wght@400;700;900&display=swap"
            rel="stylesheet"
        />

        <style>
            /* Custom Local Fonts */
            @font-face {
                font-family: "LEMONMILK";
                src: url("/fonts/LEMONMILK-Bold.otf") format("opentype");
                font-weight: bold;
                font-style: normal;
            }

            @font-face {
                font-family: "Whitney";
                src: url("/fonts/whitney-bold.otf") format("opentype");
                font-weight: bold;
                font-style: normal;
            }

            :root {
                --bg-base: #020402;
                --accent-green: #0ffd02;
                --text-main: #ffffff;
                --text-muted: #aaaaaa;
                --card-bg: rgba(20, 20, 20, 0.4);
                --border-color: rgba(255, 255, 255, 0.08);
                --font-stack:
                    "LEMONMILK", "Whitney", "Noto Sans KR", sans-serif;
                --font-kr: "Noto Sans KR", sans-serif;
                --font-dm: "DM Sans", "Noto Sans KR", sans-serif;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                -webkit-tap-highlight-color: transparent;
            }

            body {
                font-family: var(--font-stack);
                background-color: var(--bg-base);
                color: var(--text-main);
                line-height: 1.5;
                -webkit-font-smoothing: antialiased;
                overflow-x: hidden;
            }

            /* 1. Background Image */
            .bg-dark-wave {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: -1;
                background-color: var(--bg-base);
                background-image: url("/assets/background.png");
                background-size: cover;
                background-attachment: fixed;
                background-position: center;
            }

            .highlight {
                color: var(--accent-green);
            }

            /* Force Korean font where appropriate without breaking English fonts */
            .kor {
                font-family: var(--font-kr);
            }

            /* VIEW TOGGLE */
            .pc-view {
                display: none;
            }
            .mobile-view {
                display: flex;
                flex-direction: column;
                width: 100%;
                min-height: 100vh;
            }

            /* ======== MOBILE STYLES ======== */
            .mobile-container {
                width: 100%;
                max-width: 480px;
                margin: 0 auto;
                position: relative;
                display: flex;
                flex-direction: column;
                z-index: 1;
                padding-bottom: 60px;
            }

            /* Header / Logo */
            header {
                padding: 24px 24px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                position: sticky;
                top: 0;
                z-index: 100;
                background: linear-gradient(
                    180deg,
                    rgba(2, 4, 2, 0.9) 0%,
                    transparent 100%
                );
            }
            .logo-img {
                height: 28px;
                width: auto;
            }

            /* Hero */
            .hero {
                padding: 40px 24px 30px;
                text-align: left;
            }
            .hero h1 {
                font-family: "LEMONMILK", sans-serif;
                font-size: 46px;
                line-height: 1.1;
                margin-bottom: 24px;
                letter-spacing: -1px;
                text-transform: uppercase;
            }
            .hero p.sub-copy {
                font-family: var(--font-kr);
                font-size: 16px;
                font-weight: 700;
                color: rgba(255, 255, 255, 0.85);
                letter-spacing: -0.5px;
                word-break: keep-all;
                margin-bottom: 40px;
                line-height: 1.5;
            }

            /* News Cards */
            .latest-news {
                padding: 0 24px 40px;
            }
            .section-title {
                font-size: 18px;
                font-weight: 800;
                margin-bottom: 24px;
                display: flex;
                align-items: center;
                gap: 8px;
                letter-spacing: 0.5px;
                font-family: "LEMONMILK", sans-serif;
            }
            .section-title::before {
                content: "";
                display: block;
                width: 4px;
                height: 18px;
                background-color: var(--accent-green);
            }
            .loading-skeleton {
                animation: pulse-skeleton 1.5s infinite ease-in-out;
                pointer-events: none;
            }
            .loading-skeleton .news-title {
                color: rgba(255, 255, 255, 0.5);
            }
            @keyframes pulse-skeleton {
                0% {
                    opacity: 0.6;
                }
                50% {
                    opacity: 1;
                }
                100% {
                    opacity: 0.6;
                }
            }
            .news-card {
                background-color: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                overflow: hidden;
                margin-bottom: 20px;
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                transition:
                    transform 0.2s ease,
                    border-color 0.3s ease;
            }
            .news-card:active {
                transform: scale(0.98);
                border-color: var(--accent-green);
            }
            .news-image {
                width: 100%;
                height: 200px;
                background-color: #0a0e0a;
                position: relative;
            }
            .news-badge {
                position: absolute;
                top: 16px;
                left: 16px;
                background-color: var(--accent-green);
                color: #000;
                padding: 4px 10px;
                font-size: 12px;
                font-family: "LEMONMILK", sans-serif;
                border-radius: 4px;
                text-transform: uppercase;
            }
            .news-content {
                padding: 20px;
            }
            .news-title {
                font-family: var(--font-kr);
                font-size: 18px;
                font-weight: 700;
                margin-bottom: 12px;
                line-height: 1.4;
                color: #fff;
                letter-spacing: -0.5px;
            }
            .news-meta {
                font-family: var(--font-kr);
                font-size: 13px;
                color: var(--text-muted);
                display: flex;
                justify-content: space-between;
            }

            .no-ads-notice {
                font-family: var(--font-kr);
                font-size: 12px;
                color: #888888;
                text-align: center;
                margin-top: 16px;
            }

            /* Instagram CTA */
            .instagram-cta {
                margin: 20px 24px 60px;
                background: rgba(20, 25, 20, 0.6);
                border: 1px solid rgba(15, 253, 2, 0.4);
                border-radius: 20px;
                padding: 40px 24px;
                text-align: center;
                backdrop-filter: blur(12px);
            }
            .instagram-cta h2 {
                font-family: "LEMONMILK", sans-serif;
                font-size: 24px;
                margin-bottom: 12px;
                color: #fff;
            }
            .instagram-cta p {
                font-family: var(--font-dm);
                font-weight: 700;
                font-size: 15px;
                margin-bottom: 28px;
                color: var(--text-muted);
                line-height: 1.5;
                word-break: keep-all;
            }
            .btn-instagram {
                display: inline-block;
                background-color: var(--accent-green);
                color: #000;
                text-decoration: none;
                padding: 16px 32px;
                border-radius: 30px;
                font-family: var(--font-dm);
                font-weight: 700;
                font-size: 16px;
                transition: all 0.3s ease;
                letter-spacing: -0.5px;
                width: 100%;
                box-sizing: border-box;
            }
            .btn-instagram:active {
                transform: translateY(2px);
                opacity: 0.9;
            }

            /* Footer */
            footer {
                padding: 40px 24px 60px;
                border-top: 1px solid var(--border-color);
                color: var(--text-muted);
                font-size: 13px;
                text-align: center;
                font-family: var(--font-dm);
                font-weight: 700;
            }
            .footer-logo {
                font-size: 18px;
                font-family: var(--font-dm);
                font-weight: 700;
                margin-bottom: 12px;
            }

            /* ======== PC STYLES ======== */
            @media (min-width: 768px) {
                .mobile-view {
                    display: none;
                }
                .pc-view {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                    min-height: 100vh;
                    text-align: center;
                    z-index: 10;
                    position: relative;
                    padding: 40px;
                }

                .pc-main-copy {
                    font-family: "LEMONMILK", sans-serif;
                    font-size: 72px;
                    line-height: 1.1;
                    margin-bottom: 60px;
                    text-transform: uppercase;
                    letter-spacing: -1.5px;
                }

                .pc-logo-container {
                    margin-bottom: 40px;
                }
                .pc-logo-container img {
                    height: 60px;
                    width: auto;
                }

                .pc-sub-copy {
                    font-family: var(--font-kr);
                    font-size: 20px;
                    font-weight: 700;
                    color: rgba(255, 255, 255, 0.85);
                    margin-bottom: 60px;
                    letter-spacing: -0.5px;
                }

                .pc-glass-box {
                    background: rgba(255, 255, 255, 0.03);
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    backdrop-filter: blur(20px);
                    -webkit-backdrop-filter: blur(20px);
                    border-radius: 24px;
                    padding: 40px 60px;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
                    max-width: 500px;
                }

                .pc-glass-text {
                    font-family: var(--font-kr);
                    font-size: 16px;
                    color: var(--text-main);
                    font-weight: 400;
                    margin-bottom: 24px;
                    line-height: 1.6;
                    word-break: keep-all;
                    letter-spacing: -0.5px;
                }

                .pc-qr-img {
                    width: 200px;
                    height: 200px;
                    border-radius: 12px;
                    object-fit: contain;
                    box-shadow: 0 0 20px rgba(15, 253, 2, 0.15);
                }
            }
        </style>
    </head>
