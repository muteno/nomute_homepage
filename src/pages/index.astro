---
// src/pages/index.astro
---

<!doctype html>
<html lang="ko">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
        />
        <title>No Mute - THE VOICE OF THE UNHEARD.</title>
        <meta
            name="description"
            content="No Mute - 불편한 진실을 대면할 현명한 당신을 위합니다."
        />
        <!-- Pretendard Font -->
        <link
            rel="stylesheet"
            as="style"
            crossorigin
            href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
        />
        <style>
            :root {
                --bg-base: #020202;
                --accent-green: #0ffd02;
                --text-main: #ffffff;
                --text-muted: #aaaaaa;
                --card-bg: rgba(20, 20, 20, 0.6);
                --border-color: rgba(255, 255, 255, 0.1);
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                -webkit-tap-highlight-color: transparent;
            }

            body {
                font-family:
                    "Pretendard Variable",
                    Pretendard,
                    -apple-system,
                    BlinkMacSystemFont,
                    system-ui,
                    sans-serif;
                background-color: var(--bg-base);
                color: var(--text-main);
                line-height: 1.5;
                -webkit-font-smoothing: antialiased;
                overflow-x: hidden;
            }

            /* 1) Dark Abstract Gradient Wave Background (CSS Only) */
            .bg-dark-wave {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: -1;
                background: #020202;
                overflow: hidden;
            }
            .bg-dark-wave::before {
                content: "";
                position: absolute;
                width: 150vw;
                height: 150vh;
                top: -25vh;
                left: -25vw;
                background:
                    radial-gradient(
                        ellipse at 20% 40%,
                        rgba(15, 253, 2, 0.1) 0%,
                        transparent 40%
                    ),
                    radial-gradient(
                        ellipse at 80% 70%,
                        rgba(15, 253, 2, 0.05) 0%,
                        transparent 50%
                    ),
                    radial-gradient(
                        circle at 50% 10%,
                        rgba(30, 30, 35, 0.6) 0%,
                        transparent 50%
                    );
                filter: blur(90px);
                opacity: 0.9;
                animation: drift 25s infinite alternate ease-in-out;
            }
            .bg-dark-wave::after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background:
                    linear-gradient(
                        180deg,
                        transparent 0%,
                        rgba(0, 0, 0, 0.8) 100%
                    ),
                    radial-gradient(
                        120% 100% at 50% 0%,
                        transparent 40%,
                        #000 100%
                    );
            }
            @keyframes drift {
                0% {
                    transform: rotate(-3deg) scale(1);
                }
                100% {
                    transform: rotate(3deg) scale(1.1);
                }
            }

            .highlight {
                color: var(--accent-green);
            }

            /* VIEW TOGGLE */
            .pc-view {
                display: none;
            }
            .mobile-view {
                display: flex;
                flex-direction: column;
                width: 100%;
                min-height: 100vh;
            }

            /* ======== MOBILE STYLES ======== */
            .mobile-container {
                width: 100%;
                max-width: 480px;
                margin: 0 auto;
                position: relative;
                display: flex;
                flex-direction: column;
                z-index: 1;
                padding-bottom: 60px;
            }

            /* Header / Logo */
            header {
                padding: 24px 24px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                position: sticky;
                top: 0;
                z-index: 100;
                background: linear-gradient(
                    180deg,
                    rgba(0, 0, 0, 0.9) 0%,
                    transparent 100%
                );
            }
            .logo-img {
                height: 28px;
                width: auto;
            }

            /* Hero */
            .hero {
                padding: 40px 24px 20px;
                text-align: left;
            }
            .hero h1 {
                font-size: 48px;
                font-weight: 900;
                line-height: 1.1;
                margin-bottom: 24px;
                letter-spacing: -1px;
                text-transform: uppercase;
            }
            .hero p {
                font-size: 16px;
                font-weight: 400;
                color: rgba(255, 255, 255, 0.8);
                letter-spacing: -0.5px;
                word-break: keep-all;
                margin-bottom: 40px;
            }

            /* News Cards */
            .latest-news {
                padding: 0 24px 40px;
            }
            .section-title {
                font-size: 18px;
                font-weight: 800;
                margin-bottom: 24px;
                display: flex;
                align-items: center;
                gap: 8px;
                letter-spacing: -0.5px;
            }
            .section-title::before {
                content: "";
                display: block;
                width: 4px;
                height: 18px;
                background-color: var(--accent-green);
            }
            .news-card {
                background-color: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                overflow: hidden;
                margin-bottom: 20px;
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
                transition:
                    transform 0.2s ease,
                    border-color 0.3s ease;
            }
            .news-card:active {
                transform: scale(0.98);
                border-color: var(--accent-green);
            }
            .news-image {
                width: 100%;
                height: 200px;
                background-color: #111;
                position: relative;
            }
            .news-badge {
                position: absolute;
                top: 16px;
                left: 16px;
                background-color: var(--accent-green);
                color: #000;
                padding: 4px 10px;
                font-size: 12px;
                font-weight: 800;
                border-radius: 4px;
                text-transform: uppercase;
            }
            .news-content {
                padding: 20px;
            }
            .news-title {
                font-size: 18px;
                font-weight: 700;
                margin-bottom: 12px;
                line-height: 1.4;
                color: #fff;
                letter-spacing: -0.5px;
            }
            .news-meta {
                font-size: 13px;
                color: var(--text-muted);
                display: flex;
                justify-content: space-between;
            }

            /* Instagram CTA */
            .instagram-cta {
                margin: 20px 24px 60px;
                background: rgba(20, 20, 20, 0.8);
                border: 1px solid rgba(15, 253, 2, 0.3);
                border-radius: 20px;
                padding: 40px 24px;
                text-align: center;
                backdrop-filter: blur(10px);
            }
            .instagram-cta h2 {
                font-size: 24px;
                font-weight: 800;
                margin-bottom: 12px;
                color: #fff;
            }
            .instagram-cta p {
                font-size: 15px;
                margin-bottom: 28px;
                color: var(--text-muted);
                line-height: 1.5;
                word-break: keep-all;
            }
            .btn-instagram {
                display: inline-block;
                background-color: var(--accent-green);
                color: #000;
                text-decoration: none;
                padding: 16px 32px;
                border-radius: 30px;
                font-weight: 800;
                font-size: 16px;
                transition: all 0.3s ease;
                letter-spacing: -0.5px;
                width: 100%;
                box-sizing: border-box;
            }
            .btn-instagram:active {
                transform: translateY(2px);
                opacity: 0.9;
            }

            /* Footer */
            footer {
                padding: 40px 24px 60px;
                border-top: 1px solid var(--border-color);
                color: var(--text-muted);
                font-size: 13px;
                text-align: center;
            }
            .footer-logo {
                font-size: 18px;
                font-weight: 900;
                margin-bottom: 12px;
            }
            .footer-logo span {
                color: var(--accent-green);
            }

            /* ======== PC STYLES ======== */
            @media (min-width: 768px) {
                .mobile-view {
                    display: none;
                }
                .pc-view {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                    min-height: 100vh;
                    text-align: center;
                    z-index: 10;
                    position: relative;
                }
                .pc-logo-container img {
                    height: 50px;
                    margin-bottom: 30px;
                }
                .pc-message {
                    font-size: 24px;
                    font-weight: 700;
                    color: #fff;
                    margin-bottom: 40px;
                    letter-spacing: -0.5px;
                }
                .qr-container {
                    background: #fff;
                    padding: 20px;
                    border-radius: 16px;
                    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
                    display: inline-block;
                }
            }
        </style>
    </head>
    <body>
        <!-- 1. Background -->
        <div class="bg-dark-wave"></div>

        <!-- 2. PC View (> 768px) -->
        <div class="pc-view">
            <div class="pc-logo-container">
                <!-- Used imported logo image directly -->
                <img src="/assets/logo_투명.png" alt="No Mute Logo" />
            </div>
            <div class="pc-message">모바일에서 접속해주세요</div>
            <div class="qr-container">
                <div id="qrcode"></div>
            </div>
        </div>

        <!-- 3. Mobile View (<= 767px) -->
        <div class="mobile-view">
            <div class="mobile-container">
                <header>
                    <!-- Header Logo Image -->
                    <img
                        src="/assets/logo_투명.png"
                        alt="No Mute"
                        class="logo-img"
                    />
                </header>

                <!-- Hero Section -->
                <section class="hero">
                    <h1>
                        THE <span class="highlight">VOICE</span><br />OF THE<br
                        /><span class="highlight">UNHEARD</span>.
                    </h1>
                    <p>불편한 진실을 대면할 현명한 당신을 위합니다.</p>
                </section>

                <!-- Latest News (Cards in Korean) -->
                <section class="latest-news">
                    <h2 class="section-title">LATEST DROPS</h2>

                    <article class="news-card">
                        <div class="news-image">
                            <div class="news-badge">Breaking</div>
                            <div
                                style="width:100%; height:100%; background: linear-gradient(135deg, #1f1f1f, #0a0a0a);"
                            >
                            </div>
                        </div>
                        <div class="news-content">
                            <h3 class="news-title">
                                무언의 반란: 언더그라운드 크리에이터들이 주류를
                                장악하는 방법
                            </h3>
                            <div class="news-meta">
                                <span>에디터 포커스</span>
                                <span>2시간 전</span>
                            </div>
                        </div>
                    </article>

                    <article class="news-card">
                        <div class="news-image">
                            <div
                                class="news-badge"
                                style="background-color: #3b82f6; color: #fff;"
                            >
                                Culture
                            </div>
                            <div
                                style="width:100%; height:100%; background: linear-gradient(135deg, #182848, #0a0a0a);"
                            >
                            </div>
                        </div>
                        <div class="news-content">
                            <h3 class="news-title">
                                네온 시대: 현대 패션에서 대안적 미학의 부상과
                                시사점
                            </h3>
                            <div class="news-meta">
                                <span>스튜디오 제로</span>
                                <span>5시간 전</span>
                            </div>
                        </div>
                    </article>
                </section>

                <!-- Instagram CTA -->
                <section class="instagram-cta">
                    <h2>JOIN THE MOVEMENT</h2>
                    <p>
                        Instagram에서 NO MUTE의 독점 스토리와 가장 빠른 최신
                        이슈 업데이트를 확인하세요.
                    </p>
                    <a
                        href="https://instagram.com/no_mute"
                        class="btn-instagram"
                        target="_blank"
                        rel="noopener noreferrer">@no_mute 연결</a
                    >
                </section>

                <!-- Footer -->
                <footer>
                    <!-- Footer Text uses text highlight for 'NO' -->
                    <div class="footer-logo"><span>NO</span> MUTE NEWS</div>
                    <p>&copy; 2026 No Mute Media. All rights reserved.</p>
                    <p style="margin-top: 8px; opacity: 0.5;">
                        Break the silence. Speak the truth.
                    </p>
                </footer>
            </div>
        </div>

        <!-- QR Code Script & Interactions -->
        <script
            src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"
        ></script>
        <script>
            // Use ResizeObserver or matchMedia to avoid creating Multiple QRCodes
            const qrContainer = document.getElementById("qrcode");

            function initQR() {
                if (window.innerWidth >= 768 && qrContainer.innerHTML === "") {
                    new QRCode(qrContainer, {
                        text: "https://instagram.com/no_mute",
                        width: 160,
                        height: 160,
                        colorDark: "#000000",
                        colorLight: "#ffffff",
                        correctLevel: QRCode.CorrectLevel.H,
                    });
                }
            }

            initQR();
            window.addEventListener("resize", initQR);

            // Mobile card tap interactions
            const cards = document.querySelectorAll(".news-card");
            cards.forEach((card) => {
                card.addEventListener("click", () => {
                    card.style.transform = "scale(0.98)";
                    setTimeout(() => {
                        card.style.transform = "scale(1)";
                    }, 150);
                });
            });
        </script>
    </body>
</html>
