                    left: 0;
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    z-index: -2;
                }

                .pc-video-overlay {
                    display: block;
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background: rgba(0, 0, 0, 0.3);
                    z-index: -1;
                }

                .pc-view {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                    min-height: 100vh;
                    text-align: center;
                    z-index: 10;
                    position: relative;
                    padding: 40px;
                }

                .pc-main-copy {
                    font-family: "LEMONMILK", sans-serif;
                    font-size: 72px;
                    line-height: 1.1;
                    margin-bottom: 60px;
                    text-transform: uppercase;
                    letter-spacing: -1.5px;
                }

                .pc-logo-container {
                    margin-bottom: 40px;
                }
                .pc-logo-container img {
                    height: 60px;
                    width: auto;
                }

                .pc-sub-copy {
                    font-family: var(--font-kr);
                    font-size: 20px;
                    font-weight: 700;
                    color: rgba(255, 255, 255, 0.85);
                    margin-bottom: 60px;
                    letter-spacing: -0.5px;
                }

                .pc-glass-box {
                    background: rgba(255, 255, 255, 0.03);
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    backdrop-filter: blur(20px);
                    -webkit-backdrop-filter: blur(20px);
                    border-radius: 24px;
                    padding: 40px 60px;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
                    max-width: 500px;
                }

                .pc-glass-text {
                    font-family: var(--font-kr);
                    font-size: 16px;
                    color: var(--text-main);
                    font-weight: 400;
                    margin-bottom: 24px;
                    line-height: 1.6;
                    word-break: keep-all;
                    letter-spacing: -0.5px;
                }

                .pc-qr-img {
                    width: 200px;
                    height: 200px;
                    border-radius: 12px;
                    object-fit: contain;
                    box-shadow: 0 0 20px rgba(15, 253, 2, 0.15);
                }
            }
        </style>
    </head>
    <body>
        <!-- 1. Background (Image for Mobile, Video for PC) -->
        <div class="bg-dark-wave"></div>
        <video
            class="pc-video-bg"
            autoplay
            muted
            loop
            playsinline
            poster="/assets/background.png"
        >
            <source src="/assets/Background_영상.mp4" type="video/mp4" />
        </video>
        <div class="pc-video-overlay"></div>

        <!-- 2. PC View (>= 768px) -->
        <div class="pc-view">
            <h1 class="pc-main-copy">
                <span class="highlight">Breaking</span><br />
                The Silence.<br />
                Speak the <span class="highlight">Truth</span>.
            </h1>

            <div class="pc-logo-container">
                <img src="/assets/logo.png" alt="No Mute Logo" />
            </div>

            <p class="pc-sub-copy kor">
                불편한 진실을 대면할 <span class="highlight"
                    >현명한 당신을 위합니다.</span
                >
            </p>

            <div class="pc-glass-box">
                <p class="pc-glass-text kor">
                    본 사이트는 모바일 환경에 최적화된 공간입니다.<br />아래
                    QR코드를 통해 모바일로 접속해주세요
                </p>
                <img
                    src="/assets/qr_instagram.png"
                    alt="QR Code to Instagram"
                    class="pc-qr-img"
                />
            </div>
        </div>

        <!-- 3. Mobile View (< 768px) -->
        <div class="mobile-view">
            <div class="mobile-container">
                <header id="mobile-header">
                    <img
                        src="/assets/logo.png"
                        alt="No Mute"
                        class="logo-img"
                    />
                    <div class="header-text-container">
                        불편한 진실을 대면할 <span class="highlight"
                            >현명한 당신을 위합니다.</span
                        >
                    </div>
                </header>

                <section class="hero">
                    <h1>
                        <span class="highlight">Breaking</span><br />The
                        Silence.<br />Speak the <span class="highlight"
                            >Truth</span
                        >.
                    </h1>
                    <p class="sub-copy kor">
                        불편한 진실을 대면할 <span class="highlight"
                            >현명한 당신을 위합니다.</span
                        >
                    </p>
                    <a
                        href="mailto:nomute.dictate754@passinbox.com"
                        style="display: block; margin-top: -12px; text-align: left; font-size: 13px; color: #BBBBBB; text-decoration: none; line-height: 1.5;"
                    >
                        <span
                            style="font-weight: bold; text-decoration: underline;"
                            >Contact me</span
                        ><br />
                        <span style="font-weight: normal;"
                            >mail: nomute.dictate754@passinbox.com</span
                        >
                    </a>
                </section>

                <section class="latest-news">
                    <h2 class="section-title">LATEST DROPS</h2>

                    {
                        feedsConfig.map((feed, index) => {
                            const hasData =
                                feed.data && feed.data.title !== "제목 없음";
                            const hasImage = hasData && feed.data.imageUrl;
                            const batchNum = Math.floor(index / BATCH_SIZE) + 1;
                            const isHidden = batchNum > 1;
                            const isLastInBatch = (index + 1) % BATCH_SIZE === 0;
                            return (
                                <>
                                    {index === 6 && (
                                        <div class="instagram-cta">
                                            <h2>JOIN THE MOVEMENT</h2>
                                            <p class="kor">
                                                Instagram에서{" "}
                                                <span
                                                    class="highlight"
                                                    style="font-weight: 700;"
                                                >
                                                    no_mute
                                                </span>
                                                가 전하는
                                                <br />
                                                가장 빠른 이슈 업데이트를
                                                확인하세요.
                                            </p>
                                            <a
                                                href="https://instagram.com/no_mute"
                                                class="btn-instagram"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                            >
                                                @no_mute 팔로우하기
                                            </a>
                                        </div>
                                    )}
                                    <article
                                        class={`news-card`}
                                        data-batch={batchNum}
                                        style={isHidden ? "display: none;" : ""}
                                        data-link={
                                            hasData ? feed.data.link : ""
                                        }
                                    >
                                        {hasImage ? (
                                            <div class="news-image">
                                                <div
                                                    class="news-badge"
                                                    style={`background-color: ${feed.bg}; color: ${feed.text};`}
                                                >
                                                    {feed.badge}
                                                </div>
                                                <div
                                                    style={`width:100%; height:100%; background: url('${feed.data.imageUrl}') center/cover no-repeat, ${feed.grad};`}
                                                />
                                            </div>
                                        ) : null}
                                        <div class="news-content">
                                            {!hasImage && (
                                                <div
                                                    class="news-badge"
                                                    style={`background-color: ${feed.bg}; color: ${feed.text}; position: static; transform: none; display: inline-block; margin-bottom: 12px;`}
                                                >
                                                    {feed.badge}
                                                </div>
                                            )}
                                            <h3 class="news-title">
                                                {hasData
                                                    ? feed.data.title
                                                    : "기사를 불러올 수 없습니다"}
                                            </h3>
                                            <div class="news-meta">
                                                <span>{feed.source}</span>
                                                <span class="news-time">
                                                    {hasData
                                                        ? formatTimeAgo(
                                                              feed.data.pubDate,
                                                          )
                                                        : "-"}
                                                </span>
                                            </div>
                                        </div>
                                    </article>
                                    {/* 마지막 배치(6) 끝에 팔로우 배너 */}
                                    {isLastInBatch && batchNum === MAX_BATCH && (
                                        <div class="instagram-cta" data-batch={MAX_BATCH} style="display: none;">
                                            <h2>JOIN THE MOVEMENT</h2>
                                            <p class="kor">
                                                더 많은 뉴스는 Instagram
                                                <span class="highlight" style="font-weight: 700;">
                                                    {" "}no_mute
                                                </span>
                                                에서 확인하세요.
                                            </p>
                                            <a
                                                href="https://instagram.com/no_mute"
                                                class="btn-instagram"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                            >
                                                @no_mute 채널 팔로우
                                            </a>
                                        </div>
                                    )}
                                </>
                            );
                        })
                    }

                    <button
                        id="load-more-btn"
                        class="btn-instagram"
                        style="margin-top: 10px; width: 100%; border: none; cursor: pointer; text-align: center;"
                        >더 보기</button
                    >
                </section>

                <footer>
                    <div
                        class="footer-logo"
                        style="font-family: 'Noto Sans KR', sans-serif; font-weight: 900;"
                    >
                        노뮤트 매거진
                    </div>
                    <p>ⓒ 2025-26. No_mute. All rights reserved.</p>
                    <p style="margin-top: 8px; opacity: 0.5;">
                        Break the silence. Speak the truth.
                    </p>
                </footer>
            </div>
        </div>

        <!-- Interactions -->
        <script>
            // Mobile Header Scroll Effect
            const mobileHeader = document.getElementById("mobile-header");
            const heroSection = document.querySelector(".hero");

            if (mobileHeader && heroSection) {
                window.addEventListener(
                    "scroll",
                    () => {
                        const heroBottom =
                            heroSection.getBoundingClientRect().bottom;
                        const headerHeight = mobileHeader.offsetHeight;

                        if (heroBottom <= headerHeight) {
                            mobileHeader.classList.add("scrolled");
                        } else {
                            mobileHeader.classList.remove("scrolled");
                        }
                    },
                    { passive: true },
                );
            }

            // Load More Button Logic - Progressive Batch Loading
            const loadMoreBtn = document.getElementById("load-more-btn");
            if (loadMoreBtn) {
                let currentBatch = 1;
                const maxBatch = 6;

                loadMoreBtn.addEventListener("click", () => {
                    currentBatch++;
                    // Show all elements belonging to the next batch
                    document
                        .querySelectorAll(`[data-batch="${currentBatch}"]`)
                        .forEach((el) => {
                            (el as HTMLElement).style.display = "";
                        });

                    // Hide button after last batch
                    if (currentBatch >= maxBatch) {
                        loadMoreBtn.style.display = "none";
                    }
                });
            }

            // Mobile card tap interactions and link routing
            document.querySelectorAll(".news-card").forEach((card) => {
                const htmlCard = card as HTMLElement;
                const link = htmlCard.getAttribute("data-link");

                if (link) {
                    htmlCard.style.cursor = "pointer";
                    htmlCard.onclick = () => {
                        window.open(link, "_blank");
                    };
                }

                htmlCard.addEventListener("mousedown", () => {
                    htmlCard.style.transform = "scale(0.98)";
                });
                htmlCard.addEventListener("mouseup", () => {
                    htmlCard.style.transform = "scale(1)";
                });
                htmlCard.addEventListener("mouseleave", () => {
                    htmlCard.style.transform = "scale(1)";
                });

                // for touch devices
                htmlCard.addEventListener("touchstart", () => {
                    htmlCard.style.transform = "scale(0.98)";
                });
                htmlCard.addEventListener("touchend", () => {
                    htmlCard.style.transform = "scale(1)";
                });
            });
        </script>
    </body>
</html>
