<!doctype html>
<html lang="ko">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
        />
        <title>No Mute - THE VOICE OF THE UNHEARD.</title>
        <meta
            name="description"
            content="No Mute - 불편한 진실을 대면할 현명한 당신을 위합니다."
        />

        <!-- Google Fonts: DM Sans & Noto Sans KR -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@700&family=Noto+Sans+KR:wght@400;700;900&display=swap"
            rel="stylesheet"
        />

        <style>
            /* Custom Local Fonts */
            @font-face {
                font-family: "LEMONMILK";
                src: url("/fonts/LEMONMILK-Bold.otf") format("opentype");
                font-weight: bold;
                font-style: normal;
            }

            @font-face {
                font-family: "Whitney";
                src: url("/fonts/whitney-bold.otf") format("opentype");
                font-weight: bold;
                font-style: normal;
            }

            :root {
                --bg-base: #020402;
                --accent-green: #0ffd02;
                --text-main: #ffffff;
                --text-muted: #aaaaaa;
                --card-bg: rgba(20, 20, 20, 0.4);
                --border-color: rgba(255, 255, 255, 0.08);
                --font-stack:
                    "LEMONMILK", "Whitney", "Noto Sans KR", sans-serif;
                --font-kr: "Noto Sans KR", sans-serif;
                --font-dm: "DM Sans", "Noto Sans KR", sans-serif;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                -webkit-tap-highlight-color: transparent;
            }

            body {
                font-family: var(--font-stack);
                background-color: var(--bg-base);
                color: var(--text-main);
                line-height: 1.5;
                -webkit-font-smoothing: antialiased;
                overflow-x: hidden;
            }

            /* 1. Mobile Background Image (Default) */
            .bg-dark-wave {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: -1;
                background-color: var(--bg-base);
                background-image: url("/assets/background.png");
                background-size: cover;
                background-attachment: fixed;
                background-position: center;
            }

            /* Video elements (Hidden on mobile by default) */
            .pc-video-bg {
                display: none;
            }
            .pc-video-overlay {
                display: none;
            }

            .highlight {
                color: var(--accent-green);
            }

            /* Force Korean font where appropriate without breaking English fonts */
            .kor {
                font-family: var(--font-kr);
            }

            /* VIEW TOGGLE */
            .pc-view {
                display: none;
            }
            .mobile-view {
                display: flex;
                flex-direction: column;
                width: 100%;
                min-height: 100vh;
            }

            /* ======== MOBILE STYLES ======== */
            .mobile-container {
                width: 100%;
                max-width: 480px;
                margin: 0 auto;
                position: relative;
                display: flex;
                flex-direction: column;
                z-index: 1;
                padding-bottom: 60px;
            }

            /* Header / Logo */
            #mobile-header {
                padding: 0 24px 16px 24px;
                display: flex;
                justify-content: flex-start;
                align-items: flex-end; /* Baseline match */
                gap: 16px;
                position: sticky;
                top: 0;
                z-index: 1000;
            }

            /* Full viewport width background for blocking behind sticky nav */
            #mobile-header::before {
                content: "";
                position: absolute;
                top: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 100vw;
                height: 200%; /* Double height for smooth fade */
                background: linear-gradient(
                    180deg,
                    rgba(2, 4, 2, 0.98) 40%,
                    rgba(2, 4, 2, 0.7) 70%,
                    transparent 100%
                );
                z-index: -1;
                pointer-events: none;
                transition:
                    background 0.3s ease,
                    backdrop-filter 0.3s ease,
                    -webkit-backdrop-filter 0.3s ease;
            }

            #mobile-header.scrolled::before {
                background: linear-gradient(
                    180deg,
                    rgba(0, 0, 0, 0.98) 40%,
                    rgba(0, 0, 0, 0.8) 70%,
                    transparent 100%
                );
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
            }

            .logo-img {
                height: 64px;
                width: auto;
                flex-shrink: 0;
                transition: height 0.3s ease;
            }

            #mobile-header.scrolled .logo-img {
                height: 52px;
            }

            .header-text-container {
                font-family: var(--font-kr);
                font-size: 13px;
                font-weight: 700;
                line-height: 1.4;
                color: rgba(255, 255, 255, 0.9);
                opacity: 0;
                transform: translateX(-10px);
                transition:
                    opacity 0.4s ease,
                    transform 0.4s ease;
                white-space: nowrap;
                pointer-events: none;
                padding-bottom: 6px; /* Elevator spacing for baseline */
            }

            #mobile-header.scrolled .header-text-container {
                opacity: 1;
                transform: translateX(0);
                pointer-events: auto;
            }

            /* Hero */
            .hero {
                padding: 40px 24px 30px;
                text-align: left;
            }
            .hero h1 {
                font-family: "LEMONMILK", sans-serif;
                font-size: 46px;
                line-height: 1.1;
                margin-bottom: 24px;
                letter-spacing: -1px;
                text-transform: uppercase;
            }
            .hero p.sub-copy {
                font-family: var(--font-kr);
                font-size: 16px;
                font-weight: 700;
                color: rgba(255, 255, 255, 0.85);
                letter-spacing: -0.5px;
                word-break: keep-all;
                margin-bottom: 40px;
                line-height: 1.5;
            }

            /* News Cards */
            .latest-news {
                padding: 0 24px 40px;
            }
            .section-title {
                font-size: 18px;
                font-weight: 800;
                margin-bottom: 24px;
                display: flex;
                align-items: center;
                gap: 8px;
                letter-spacing: 0.5px;
                font-family: "LEMONMILK", sans-serif;
            }
            .section-title::before {
                content: "";
                display: block;
                width: 4px;
                height: 18px;
                background-color: var(--accent-green);
            }
            .loading-skeleton {
                animation: pulse-skeleton 1.5s infinite ease-in-out;
                pointer-events: none;
            }
            .loading-skeleton .news-title {
                color: rgba(255, 255, 255, 0.5);
            }
            @keyframes pulse-skeleton {
                0% {
                    opacity: 0.6;
                }
                50% {
                    opacity: 1;
                }
                100% {
                    opacity: 0.6;
                }
            }
            .news-card {
                background-color: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                overflow: hidden;
                margin-bottom: 20px;
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                transition:
                    transform 0.2s ease,
                    border-color 0.3s ease;
            }
            .news-card:active {
                transform: scale(0.98);
                border-color: var(--accent-green);
            }
            .news-image {
                width: 100%;
                height: 200px;
                background-color: #0a0e0a;
                position: relative;
            }
            .news-badge {
                position: absolute;
                bottom: 0;
                left: 20px;
                transform: translateY(50%);
